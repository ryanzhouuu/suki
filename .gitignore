# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# supabase CLI (local state — commit supabase/migrations/ and config.toml)
supabase/.temp/
supabase/.branches/

# drizzle
.drizzle/

# editors
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# typescript
*.tsbuildinfo
next-env.d.ts

.claude/
.cursor/
AGENTS.md
CLAUDE.md

# local agent tooling / MCP (may contain secrets — never commit)
.mcp.json
.agents/
.codex/

# superpowers planning artifacts (specs/plans kept locally, not tracked)
docs/superpowers/

# git worktrees used for isolated feature work
.worktrees/