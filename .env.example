# Supabase — Project Settings → API
# Docs: https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Client-safe (browser, Server Components with user session). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only — bypasses RLS. Format: sb_secret_...
# Needed for derived_rankings writes and other admin tasks. Never expose to the client.
SUPABASE_SECRET_KEY=your-secret-key

# Comma-separated emails allowed to use /admin/series (series grouping overrides)
SERIES_ADMIN_EMAILS=you@example.com

# Legacy names still work during migration (optional):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Database — Settings → Database → Connection string (Transaction pooler for serverless)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Auth redirects, OG tags (required in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — enable in Supabase Dashboard → Authentication → Providers → Google
# Add redirect URL: http://localhost:3000/auth/callback (and your production URL)

# Recommendations (OpenAI embeddings — server only)
OPENAI_API_KEY=sk-...

# Optional AniList OAuth access token (server only). Raises the authenticated
# rate-limit ceiling; unset behaves exactly as before (public metadata needs no
# auth). Never expose to the client. See AGENTS.md for ToS notes.
# ANILIST_TOKEN=
