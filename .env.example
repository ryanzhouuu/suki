# Supabase — Project Settings → API
# Docs: https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Client-safe (browser, Server Components with user session). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only — bypasses RLS. Format: sb_secret_...
# Needed for derived_rankings writes and other admin tasks. Never expose to the client.
SUPABASE_SECRET_KEY=your-secret-key

# Legacy names still work during migration (optional):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Database — Settings → Database → Connection string (Transaction pooler for serverless)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Auth redirects, OG tags
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Recommendations (OpenAI embeddings — server only)
OPENAI_API_KEY=sk-...
