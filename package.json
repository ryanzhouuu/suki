{
  "name": "anime-list",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "types:supabase": "echo 'Regenerate with Supabase MCP generate_typescript_types or: supabase gen types typescript'",
    "backfill:series": "npx tsx src/scripts/backfill-series.ts",
    "backfill:embeddings": "npx tsx src/scripts/backfill-anime-embeddings.ts",
    "seed:catalog": "npx tsx src/scripts/seed-recommendation-catalog.ts",
    "backfill:popular": "npx tsx src/scripts/backfill-popular-catalog.ts",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "c8 npm test",
    "test:coverage:check": "c8 check-coverage --lines 32 --functions 70 --branches 75 --statements 32"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "openai": "^6.39.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "c8": "^10.1.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
